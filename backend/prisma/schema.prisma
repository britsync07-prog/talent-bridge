// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("postgresql://bridge_user:nTdh2I2uOQ1VAclNhTch82OCpMWk7Vk3@77.237.239.69:5432/talent_bridge?schema=public")
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  role      String   @default("EMPLOYER") // ADMIN, EMPLOYER, ENGINEER
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  adminProfile    AdminProfile?
  employerProfile EmployerProfile?
  engineerProfile EngineerProfile?
  
  activity_logs    Activity_log[]
  sentMessages     Message[] @relation("SentMessages")
  receivedMessages Message[] @relation("ReceivedMessages")
}

model Message {
  id         String   @id @default(uuid())
  senderId   String
  sender     User     @relation("SentMessages", fields: [senderId], references: [id], onDelete: Cascade)
  receiverId String
  receiver   User     @relation("ReceivedMessages", fields: [receiverId], references: [id], onDelete: Cascade)
  content    String
  createdAt  DateTime @default(now())
}

model AdminProfile {
  id     String @id @default(uuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model EmployerProfile {
  id           String @id @default(uuid())
  userId       String @unique
  user         User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  companyName  String?
  website      String?
  size         String?
  industry     String?
  description  String?
  location     String?
  businessRegNumber String?
  isApproved   Boolean @default(false)
  disapprovalReason String?

  jobs         Job[]
  contracts    Contract[]
  interests    Interest[]
  savedCandidates SavedCandidate[]
}

model EngineerProfile {
  id                        String   @id @default(uuid())
  userId                    String   @unique
  user                      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  fullName                  String?
  profilePic                String?
  country                   String?
  skills                    String?   
  yearsExperience           Int?     @default(0)
  hourlyRate                Float?   @default(0)
  monthlySalaryExpectation Float?   @default(0)
  portfolioWebsite          String?
  github                    String?
  linkedin                  String?
  videoUrl                  String?
  aiSpecializations         String?   
  languages                 String?   
  availabilityStatus        String   @default("Available")
  resumeUrl                 String?
  certifications            String?
  isProfileComplete         Boolean  @default(false)
  isActive                  Boolean  @default(true)
  isApproved                Boolean  @default(false)
  approvalStatus            String   @default("PENDING") // PENDING, ACCEPTED_FOR_INTERVIEW, INTERVIEW_COMPLETED, FULLY_APPROVED, REJECTED
  disapprovalReason         String?
  isFeatured                Boolean  @default(false) // For curated "top talent" placement
  meetingId                 String?
  joinUrl                   String?

  contracts                 Contract[]
  interests                 Interest[]
  savedBy                   SavedCandidate[]
  endorsements              Endorsement[]
  certificates              Certificate[]
}

model Certificate {
  id          String          @id @default(uuid())
  engineerId  String
  engineer    EngineerProfile @relation(fields: [engineerId], references: [id], onDelete: Cascade)
  url         String
  name        String?
  createdAt   DateTime        @default(now())
}

model SavedCandidate {
  id         String   @id @default(uuid())
  employerId String
  employer   EmployerProfile @relation(fields: [employerId], references: [id], onDelete: Cascade)
  engineerId String
  engineer   EngineerProfile @relation(fields: [engineerId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())

  @@unique([employerId, engineerId])
}

model Job {
  id          String    @id @default(uuid())
  employerId  String
  employer    EmployerProfile @relation(fields: [employerId], references: [id], onDelete: Cascade)
  title       String
  description String
  requiredSkills String
  maxBudget   Float
  duration    String
  status      String    @default("PENDING") // PENDING, OPEN, CLOSED, DRAFT, DISAPPROVED
  disapprovalReason String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  interests   Interest[]
}

model Interest {
  id          String    @id @default(uuid())
  jobId       String
  job         Job       @relation(fields: [jobId], references: [id], onDelete: Cascade)
  employerId  String
  employer    EmployerProfile @relation(fields: [employerId], references: [id], onDelete: Cascade)
  engineerId  String
  engineer    EngineerProfile @relation(fields: [engineerId], references: [id], onDelete: Cascade)
  type        String    @default("LEASE") // LEASE, FULLTIME
  status      String    @default("PENDING") // PENDING, CALLED, APPROVED, REJECTED
  scheduledAt DateTime?
  meetingId   String?
  joinUrl     String?
  createdAt   DateTime  @default(now())

  @@unique([jobId, engineerId])
}

model Contract {
  id               String       @id @default(uuid())
  employerId       String
  employer         EmployerProfile @relation(fields: [employerId], references: [id], onDelete: Cascade)
  engineerId       String
  engineer         EngineerProfile @relation(fields: [engineerId], references: [id], onDelete: Cascade)
  type             String       @default("LEASE") // LEASE (Monthly), FULLTIME (6-month upfront)
  startDate        DateTime     @default(now())
  salary           Float        // Monthly salary or base
  platformFee      Float        // Fee percentage or amount
  paymentCycle     String       @default("MONTHLY")
  status           String       @default("PENDING") // PENDING, ACTIVE, TERMINATED, COMPLETED
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  tasks            Task[]
  invoices         Invoice[]
  timesheets       Timesheet[]

  @@unique([employerId, engineerId])
}

model Timesheet {
  id          String   @id @default(uuid())
  contractId  String
  contract    Contract @relation(fields: [contractId], references: [id], onDelete: Cascade)
  date        DateTime
  hours       Float
  description String?
  status      String   @default("PENDING") // PENDING, APPROVED, REJECTED
  createdAt   DateTime @default(now())
}

model Endorsement {
  id          String   @id @default(uuid())
  engineerId  String
  engineer    EngineerProfile @relation(fields: [engineerId], references: [id], onDelete: Cascade)
  fromName    String   // Name of the person/company endorsing
  content     String
  createdAt   DateTime @default(now())
}

model Task {
  id          String    @id @default(uuid())
  contractId  String
  contract    Contract  @relation(fields: [contractId], references: [id], onDelete: Cascade)
  title       String
  description String
  priority    String    @default("MEDIUM") // LOW, MEDIUM, HIGH
  deadline    DateTime?
  status      String    @default("PENDING") // PENDING, IN_PROGRESS, REVIEW, COMPLETED
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Invoice {
  id          String    @id @default(uuid())
  contractId  String
  contract    Contract  @relation(fields: [contractId], references: [id], onDelete: Cascade)
  amount      Float
  status      String    @default("UNPAID") // UNPAID, PAID, OVERDUE
  dueDate     DateTime
  createdAt   DateTime  @default(now())
  
  payment     Payment?
}

model Payment {
  id          String    @id @default(uuid())
  invoiceId   String    @unique
  invoice     Invoice   @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  amount      Float
  status      String    @default("COMPLETED")
  stripeId    String?
  createdAt   DateTime  @default(now())
}

model Activity_log {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  action    String   // user login, job posted, engineer hired, contract signed, task updated, invoice generated, payment completed, interest shown
  details   String?
  createdAt DateTime @default(now())
}

model SystemConfig {
  id        String   @id @default(uuid())
  key       String   @unique
  value     String
  updatedAt DateTime @updatedAt
}

