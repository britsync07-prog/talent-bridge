generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id               String           @id @default(uuid())
  email            String           @unique
  password         String
  role             String           @default("EMPLOYER")
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  activity_logs    Activity_log[]
  adminProfile     AdminProfile?
  employerProfile  EmployerProfile?
  engineerProfile  EngineerProfile?
  receivedMessages Message[]        @relation("ReceivedMessages")
  sentMessages     Message[]        @relation("SentMessages")
}

model Message {
  id         String   @id @default(uuid())
  senderId   String
  receiverId String
  content    String
  createdAt  DateTime @default(now())
  receiver   User     @relation("ReceivedMessages", fields: [receiverId], references: [id], onDelete: Cascade)
  sender     User     @relation("SentMessages", fields: [senderId], references: [id], onDelete: Cascade)
}

model AdminProfile {
  id     String @id @default(uuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model EmployerProfile {
  id                String           @id @default(uuid())
  userId            String           @unique
  companyName       String?
  website           String?
  size              String?
  industry          String?
  description       String?
  location          String?
  isApproved        Boolean          @default(false)
  businessRegNumber String?
  disapprovalReason String?
  contracts         Contract[]
  user              User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  interests         Interest[]
  jobs              Job[]
  savedCandidates   SavedCandidate[]
}

model EngineerProfile {
  id                       String           @id @default(uuid())
  userId                   String           @unique
  fullName                 String?
  profilePic               String?
  country                  String?
  skills                   String?
  yearsExperience          Int?             @default(0)
  hourlyRate               Float?           @default(0)
  monthlySalaryExpectation Float?           @default(0)
  portfolioWebsite         String?
  github                   String?
  linkedin                 String?
  videoUrl                 String?
  aiSpecializations        String?
  languages                String?
  availabilityStatus       String           @default("Available")
  resumeUrl                String?
  isActive                 Boolean          @default(true)
  isApproved               Boolean          @default(false)
  approvalStatus           String           @default("PENDING")
  isFeatured               Boolean          @default(false)
  meetingId                String?
  joinUrl                  String?
  disapprovalReason        String?
  isProfileComplete        Boolean          @default(false)
  certifications           String?
  certificates             Certificate[]
  contracts                Contract[]
  endorsements             Endorsement[]
  user                     User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  interests                Interest[]
  savedBy                  SavedCandidate[]
}

model Certificate {
  id         String          @id @default(uuid())
  engineerId String
  url        String
  name       String?
  createdAt  DateTime        @default(now())
  engineer   EngineerProfile @relation(fields: [engineerId], references: [id], onDelete: Cascade)
}

model SavedCandidate {
  id         String          @id @default(uuid())
  employerId String
  engineerId String
  createdAt  DateTime        @default(now())
  employer   EmployerProfile @relation(fields: [employerId], references: [id], onDelete: Cascade)
  engineer   EngineerProfile @relation(fields: [engineerId], references: [id], onDelete: Cascade)

  @@unique([employerId, engineerId])
}

model Job {
  id                String          @id @default(uuid())
  employerId        String
  title             String
  description       String
  requiredSkills    String
  maxBudget         Float
  duration          String
  status            String          @default("PENDING")
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  disapprovalReason String?
  interests         Interest[]
  employer          EmployerProfile @relation(fields: [employerId], references: [id], onDelete: Cascade)
}

model Interest {
  id          String          @id @default(uuid())
  jobId       String
  employerId  String
  engineerId  String
  type        String          @default("LEASE")
  status      String          @default("PENDING")
  scheduledAt DateTime?
  meetingId   String?
  joinUrl     String?
  createdAt   DateTime        @default(now())
  employer    EmployerProfile @relation(fields: [employerId], references: [id], onDelete: Cascade)
  engineer    EngineerProfile @relation(fields: [engineerId], references: [id], onDelete: Cascade)
  job         Job             @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@unique([jobId, engineerId])
}

model Contract {
  id           String          @id @default(uuid())
  employerId   String
  engineerId   String
  type         String          @default("LEASE")
  startDate    DateTime        @default(now())
  salary       Float
  platformFee  Float
  paymentCycle String          @default("MONTHLY")
  status       String          @default("PENDING")
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  employer     EmployerProfile @relation(fields: [employerId], references: [id], onDelete: Cascade)
  engineer     EngineerProfile @relation(fields: [engineerId], references: [id], onDelete: Cascade)
  invoices     Invoice[]
  tasks        Task[]
  timesheets   Timesheet[]

  @@unique([employerId, engineerId])
}

model Timesheet {
  id          String   @id @default(uuid())
  contractId  String
  date        DateTime
  hours       Float
  description String?
  status      String   @default("PENDING")
  createdAt   DateTime @default(now())
  contract    Contract @relation(fields: [contractId], references: [id], onDelete: Cascade)
}

model Endorsement {
  id         String          @id @default(uuid())
  engineerId String
  fromName   String
  content    String
  createdAt  DateTime        @default(now())
  engineer   EngineerProfile @relation(fields: [engineerId], references: [id], onDelete: Cascade)
}

model Task {
  id          String    @id @default(uuid())
  contractId  String
  title       String
  description String
  priority    String    @default("MEDIUM")
  deadline    DateTime?
  status      String    @default("PENDING")
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  contract    Contract  @relation(fields: [contractId], references: [id], onDelete: Cascade)
}

model Invoice {
  id         String   @id @default(uuid())
  contractId String
  amount     Float
  status     String   @default("UNPAID")
  dueDate    DateTime
  createdAt  DateTime @default(now())
  contract   Contract @relation(fields: [contractId], references: [id], onDelete: Cascade)
  payment    Payment?
}

model Payment {
  id        String   @id @default(uuid())
  invoiceId String   @unique
  amount    Float
  status    String   @default("COMPLETED")
  stripeId  String?
  createdAt DateTime @default(now())
  invoice   Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
}

model Activity_log {
  id        String   @id @default(uuid())
  userId    String
  action    String
  details   String?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model SystemConfig {
  id        String   @id @default(uuid())
  key       String   @unique
  value     String
  updatedAt DateTime @updatedAt
}
